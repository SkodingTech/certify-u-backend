# Copy this file to `.env` for local dev (never commit `.env`).
# In production, set these as real environment variables.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=certifyu
DB_USER=certifyuuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=certifyu

# Google OAuth2 (social sign-in via /auth/convert-token).
# Google Cloud Console > Credentials > OAuth 2.0 Client ID (Web application).
# The KEY (client ID) must match the frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID.
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Email — Zoho Mail SMTP (password-reset OTP delivery).
# EMAIL_HOST_PASSWORD must be a Zoho *app-specific* password, not your login one
# (Zoho Mail > Settings > Security > App Passwords). Leave EMAIL_HOST_USER blank
# in local dev to print OTP codes to the console instead of sending real email.
# Pick the SMTP host for your Zoho data region: smtp.zoho.com (global),
# smtp.zoho.eu, smtp.zoho.in, smtp.zoho.sa, ...
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@certify-u.com
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

# Admin notifications — inbox that receives alerts for new users, new/updated
# courses, new enrolments/payments, and security events (password reset/change).
# Comma-separated for multiple recipients. Defaults to DEFAULT_FROM_EMAIL.
ADMIN_NOTIFICATION_EMAIL=info@certify-u.com

# Branding used in the HTML notification email templates.
SITE_NAME=Certify-U
# Public frontend base URL — used for in-email links and the logo image.
FRONTEND_BASE_URL=https://certify-u.com
# Absolute URL of the logo shown in email headers (must be publicly reachable).
EMAIL_LOGO_URL=https://certify-u.com/assets/img/logo/logo-1.png
# Brand accent colour for buttons / header rule in emails.
EMAIL_BRAND_COLOR=#F47A20
