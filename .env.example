# Copy this file to `.env` for local dev (never commit `.env`).
# In production, set these as real environment variables.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=certifyu
DB_USER=certifyuuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=certifyu

# Google OAuth2 (social sign-in via /auth/convert-token).
# Google Cloud Console > Credentials > OAuth 2.0 Client ID (Web application).
# The KEY (client ID) must match the frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID.
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
